---
---

<section id="testimonials" class="py-24 px-6 md:px-12 bg-[#0a0a0a] border-b border-primary-gold/55">
  
  <div class="max-w-[1280px] w-full mx-auto">
    
    <!-- Title row with editorial styling -->
    <div class="text-center mb-16">
      <span class="font-mono-tag text-[9px] text-primary-gold tracking-[0.4em] uppercase mb-4 block">05 / TESTIMONIOS</span>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
        Casos de <span class="font-serif-italic text-primary-gold font-normal italic capitalize">confianza prestige</span>
      </h2>
    </div>

    <!-- Testimonials grid cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Card 1 -->
      <div class="testimonial-card group p-8 md:p-10 rounded-[2rem] border border-primary-gold/55 bg-[#121212] relative overflow-hidden transition-colors duration-500 hover:bg-primary-gold/[0.01] hover:border-primary-gold/75 flex flex-col justify-between min-h-[320px]">
        <div>
          <!-- Giant luxury quote mark -->
          <span class="font-serif-italic text-5xl text-primary-gold/25 block mb-4">“</span>
          <p class="font-mono-tag text-[10px] text-white/70 leading-relaxed uppercase tracking-wider mb-6 italic">
            El trabajo de Facundo transformó nuestra presencia online por completo. Su enfoque técnico y estética minimalista atrajo a clientes de alto perfil que antes no podíamos capturar. 100% recomendado.
          </p>
        </div>
        <div class="border-t border-primary-gold/55 pt-4 flex flex-col">
          <span class="font-bold text-sm text-primary-gold">Alejandro Varela</span>
          <span class="font-mono-tag text-[8px] text-white/30 tracking-widest uppercase mt-1">Founder, Titan Fitness Enterprise</span>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="testimonial-card group p-8 md:p-10 rounded-[2rem] border border-primary-gold/55 bg-[#121212] relative overflow-hidden transition-colors duration-500 hover:bg-primary-gold/[0.01] hover:border-primary-gold/75 flex flex-col justify-between min-h-[320px]">
        <div>
          <!-- Giant luxury quote mark -->
          <span class="font-serif-italic text-5xl text-primary-gold/25 block mb-4">“</span>
          <p class="font-mono-tag text-[10px] text-white/70 leading-relaxed uppercase tracking-wider mb-6 italic">
            Obsesionado con el rendimiento. Logró que nuestro sitio de reservas cargue en menos de un segundo (100/100 Lighthouse) manteniendo animaciones orgánicas fluidas y bellísimas.
          </p>
        </div>
        <div class="border-t border-primary-gold/55 pt-4 flex flex-col">
          <span class="font-bold text-sm text-primary-gold">Elena de la Rosa</span>
          <span class="font-mono-tag text-[8px] text-white/30 tracking-widest uppercase mt-1">Marketing Director, Aura Fine Dining</span>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="testimonial-card group p-8 md:p-10 rounded-[2rem] border border-primary-gold/55 bg-[#121212] relative overflow-hidden transition-colors duration-500 hover:bg-primary-gold/[0.01] hover:border-primary-gold/75 flex flex-col justify-between min-h-[320px]">
        <div>
          <!-- Giant luxury quote mark -->
          <span class="font-serif-italic text-5xl text-primary-gold/25 block mb-4">“</span>
          <p class="font-mono-tag text-[10px] text-white/70 leading-relaxed uppercase tracking-wider mb-6 italic">
            Ingeniería de primer nivel. Entiende la diferencia entre una web funcional y una web de lujo. La modularidad y la pulcritud de su código es digno de admirar.
          </p>
        </div>
        <div class="border-t border-primary-gold/55 pt-4 flex flex-col">
          <span class="font-bold text-sm text-primary-gold">Marcus Sterling</span>
          <span class="font-mono-tag text-[8px] text-white/30 tracking-widest uppercase mt-1">CTO, Aurelius Tech Ventures</span>
        </div>
      </div>

    </div>

  </div>

</section>
