<section id="projects" class="py-24 md:py-16 md:h-screen border-b border-primary-gold/55 overflow-hidden bg-[#0a0a0a] md:flex md:flex-col md:justify-between">
  
  <!-- Section Title -->
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 mb-12 md:mb-6 text-center">
    <span class="font-mono-tag text-[9px] text-primary-gold tracking-[0.4em] uppercase mb-4 block">02 / PORTFOLIO</span>
    <h2 class="text-4xl md:text-5xl font-bold tracking-tight">
      Selección <span class="font-serif-italic text-primary-gold font-normal normal-case italic">Prestige</span>
    </h2>
  </div>

  <!-- Fanning/Stacking Cards Container (Pinned on Scroll on Desktop) -->
  <div id="projects-pin-container" class="relative w-full max-w-[960px] mx-auto px-6 md:px-12 flex-grow flex flex-col items-center justify-start min-h-[60vh] md:min-h-0 md:pt-4">
    
    <!-- Project Card 1 -->
    <div class="project-card w-full max-w-[960px] grid grid-cols-1 md:grid-cols-12 gap-8 p-6 md:p-10 rounded-[2rem] border border-primary-gold/55 bg-[#121212]/90 backdrop-blur-md relative z-10 md:absolute md:top-0 shadow-2xl transition-all duration-300 hover:border-primary-gold/50">
      
      <!-- Abstract Premium Placeholder Image -->
      <div class="md:col-span-7 aspect-[16/10] w-full rounded-2xl overflow-hidden relative bg-[#181818] border border-primary-gold/35 flex items-center justify-center group">
        <!-- Luxury Gradient Glow -->
        <div class="absolute inset-0 bg-gradient-to-br from-primary-gold/5 via-transparent to-transparent opacity-60"></div>
        <div class="absolute w-[200px] h-[200px] bg-primary-gold/5 rounded-full filter blur-[40px] group-hover:scale-125 transition-transform duration-700"></div>
        
        <!-- Abstract geometry SVG -->
        <svg class="w-24 h-24 text-primary-gold/20 group-hover:text-primary-gold/40 transition-colors duration-500" viewBox="0 0 100 100" fill="none">
          <circle cx="50" cy="50" r="30" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2" />
          <polygon points="50,15 80,75 20,75" stroke="currentColor" stroke-width="0.75" />
          <circle cx="50" cy="50" r="8" fill="currentColor" fill-opacity="0.1" />
        </svg>

        <span class="absolute bottom-4 left-6 font-mono-tag text-[8px] text-white/30 tracking-widest uppercase">Placeholder — Titan Gym</span>
      </div>

      <!-- Description Content -->
      <div class="md:col-span-5 flex flex-col justify-between py-2">
        <div>
          <span class="font-mono-tag text-[9px] text-primary-gold tracking-[0.3em] uppercase mb-4 block">FITNESS ENTERPRISE</span>
          <h3 class="text-2xl md:text-3xl font-bold mb-4">Titan Gym Platform</h3>
          <p class="font-mono-tag text-[10px] text-white/50 leading-relaxed uppercase tracking-wider mb-6">
            Una solución integral de gestión administrativa en tiempo real que sincroniza pagos, membresías y accesos de más de 1200 usuarios activos.
          </p>
        </div>
        <div>
          <!-- Tech tags -->
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="font-mono-tag text-[8px] tracking-widest text-primary-gold uppercase px-3 py-1 border border-primary-gold/45 rounded-full bg-primary-gold/5">Firebase SDK</span>
            <span class="font-mono-tag text-[8px] tracking-widest text-primary-gold uppercase px-3 py-1 border border-primary-gold/45 rounded-full bg-primary-gold/5">React.js</span>
            <span class="font-mono-tag text-[8px] tracking-widest text-primary-gold uppercase px-3 py-1 border border-primary-gold/45 rounded-full bg-primary-gold/5">Stripe API</span>
          </div>
          <a href="#" class="inline-flex items-center gap-2 text-primary-gold font-mono-tag text-[10px] tracking-widest uppercase hover:gap-4 transition-all">
            Explorar Estudio
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>

    </div>

    <!-- Project Card 2 -->
    <div class="project-card w-full max-w-[960px] grid grid-cols-1 md:grid-cols-12 gap-8 p-6 md:p-10 rounded-[2rem] border border-primary-gold/55 bg-[#121212]/90 backdrop-blur-md relative z-20 md:absolute md:top-8 mt-8 md:mt-0 shadow-2xl transition-all duration-300 hover:border-primary-gold/50">
      
      <!-- Abstract Premium Placeholder Image -->
      <div class="md:col-span-7 aspect-[16/10] w-full rounded-2xl overflow-hidden relative bg-[#181818] border border-primary-gold/35 flex items-center justify-center group">
        <!-- Luxury Gradient Glow -->
        <div class="absolute inset-0 bg-gradient-to-br from-primary-gold/5 via-transparent to-transparent opacity-60"></div>
        <div class="absolute w-[200px] h-[200px] bg-primary-gold/5 rounded-full filter blur-[40px] group-hover:scale-125 transition-transform duration-700"></div>
        
        <!-- Abstract geometry SVG -->
        <svg class="w-24 h-24 text-primary-gold/20 group-hover:text-primary-gold/40 transition-colors duration-500" viewBox="0 0 100 100" fill="none">
          <circle cx="50" cy="50" r="35" stroke="currentColor" stroke-width="0.5" />
          <circle cx="50" cy="50" r="20" stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 4" />
          <path d="M15,50 H85 M50,15 V85" stroke="currentColor" stroke-width="0.25" />
          <rect x="42" y="42" width="16" height="16" stroke="currentColor" stroke-width="0.75" transform="rotate(45 50 50)" fill="currentColor" fill-opacity="0.05" />
        </svg>

        <span class="absolute bottom-4 left-6 font-mono-tag text-[8px] text-white/30 tracking-widest uppercase">Placeholder — Aura Dining</span>
      </div>

      <!-- Description Content -->
      <div class="md:col-span-5 flex flex-col justify-between py-2">
        <div>
          <span class="font-mono-tag text-[9px] text-primary-gold tracking-[0.3em] uppercase mb-4 block">LUXURY EDITORIAL</span>
          <h3 class="text-2xl md:text-3xl font-bold mb-4">Aura Fine Dining</h3>
          <p class="font-mono-tag text-[10px] text-white/50 leading-relaxed uppercase tracking-wider mb-6">
            Diseño inmersivo para alta cocina, con sistema de reservas inteligente y transiciones de imagen fluidas que imitan el movimiento orgánico.
          </p>
        </div>
        <div>
          <!-- Tech tags -->
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="font-mono-tag text-[8px] tracking-widest text-primary-gold uppercase px-3 py-1 border border-primary-gold/45 rounded-full bg-primary-gold/5">Three.js</span>
            <span class="font-mono-tag text-[8px] tracking-widest text-primary-gold uppercase px-3 py-1 border border-primary-gold/45 rounded-full bg-primary-gold/5">GSAP Core</span>
            <span class="font-mono-tag text-[8px] tracking-widest text-primary-gold uppercase px-3 py-1 border border-primary-gold/45 rounded-full bg-primary-gold/5">Astro SSG</span>
          </div>
          <a href="#" class="inline-flex items-center gap-2 text-primary-gold font-mono-tag text-[10px] tracking-widest uppercase hover:gap-4 transition-all">
            Explorar Estudio
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>

    </div>

  </div>

</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Fanning Stacking Card animation on desktop (screens >= 768px)
  const initFanningCards = () => {
    const isDesktop = window.matchMedia('(min-width: 768px)').matches;
    if (!isDesktop) return;

    const cards = gsap.utils.toArray('.project-card');
    const container = document.getElementById('projects-pin-container');
    
    if (!container || cards.length < 2) return;

    // Create stacking fanning scroll trigger
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '#projects',
        start: 'top top',
        end: '+=1000',       // Balanced scroll depth to absorb velocity without feeling slow
        scrub: 0.4,          // Smooth catch-up to prevent visual skipping or flashing on fast scroll
        pin: true,           // Pin the whole projects section
        anticipatePin: 1,
        fastScrollEnd: true, // Force completion on fast scroll
        preventOverlaps: true,
        snap: {
          snapTo: 1,         // Snap magnetically to Card 1 (0) or Card 2 (1)
          duration: 0.4,
          delay: 0.05,
          ease: 'power2.out'
        }
      }
    });

    // Card 1 starts at top
    // Card 2 animates from below, scaling, rotating slightly, and overlaying Card 1 in a beautiful fan layout
    tl.fromTo(cards[1] as HTMLElement,
      { 
        yPercent: 120, 
        scale: 0.9,
        rotation: 4
      },
      { 
        yPercent: 0, 
        scale: 1,
        rotation: -2,
        ease: 'none'        // 1:1 linear progression with scrollbar, perfect for scrub
      }
    );
  };

  // Re-run setup on site loaded event
  window.addEventListener('site-loaded', () => {
    initFanningCards();
  });
</script>
