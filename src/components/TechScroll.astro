        </div>
      </div>

    </div>

  </div>
</section>

<style>
  @keyframes marquee {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(-50%, 0, 0);
    }
  }

  .animate-marquee {
    animation: marquee 35s linear infinite;
  }
  
  .animate-marquee:hover {
    animation-play-state: paused;
  }
</style>
