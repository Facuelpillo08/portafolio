<section id="process" class="relative bg-[#0b0b0b] overflow-hidden border-b border-primary-gold/55 py-24 min-h-screen flex flex-col justify-between">
  
  <!-- Cell grid decoration behind slides -->
  <div class="absolute inset-0 grid grid-cols-4 pointer-events-none opacity-[0.08]">
    <div class="border-r border-primary-gold/65 h-full"></div>
    <div class="border-r border-primary-gold/65 h-full"></div>
    <div class="border-r border-primary-gold/65 h-full"></div>
    <div></div>
  </div>

  <!-- Top Section Info -->
  <div class="w-full max-w-[1280px] mx-auto px-6 md:px-12 flex justify-between items-end relative z-10 mb-8">
    <div>
      <span class="font-mono-tag text-[9px] text-primary-gold tracking-[0.4em] uppercase mb-4 block">03 / METODOLOGÍA</span>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
        Ingeniería de <span class="font-serif-italic text-primary-gold font-normal italic capitalize">alto impacto</span>
      </h2>
    </div>
    <span class="hidden sm:block font-mono-tag text-[10px] text-white/30 tracking-[0.2em] uppercase">MUEVE EL SCROLL →</span>
  </div>

  <!-- Horizontal Slides Wrapper (ScrollTrigger slides this container left) -->
  <div id="slides-track" class="flex w-[400vw] md:w-[250vw] lg:w-[200vw] h-[50vh] items-center relative z-10 pl-6 md:pl-24 gap-8 md:gap-16 cursor-default my-8">
    
    <!-- Step 1 -->
    <div class="process-slide w-[80vw] md:w-[45vw] lg:w-[35vw] flex-shrink-0 h-full p-8 md:p-12 rounded-[2rem] border border-primary-gold/55 bg-[#121212] flex flex-col justify-between relative overflow-hidden group hover:border-primary-gold/50 transition-colors duration-300">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-gold/[0.02] to-transparent opacity-100"></div>
      <div class="text-6xl md:text-8xl font-serif-italic text-primary-gold/10 font-normal select-none group-hover:text-primary-gold/25 transition-colors duration-500">01</div>
      <div>
        <h3 class="text-xl md:text-2xl font-bold mb-4">Audit & Discovery</h3>
        <p class="font-mono-tag text-[10px] text-white/50 leading-relaxed uppercase tracking-wider">
          Analizamos el ADN de tu negocio en profundidad para encontrar la ventaja competitiva técnica y visual óptima en el mercado.
        </p>
      </div>
      <div class="w-full h-[1px] bg-primary-gold/30 mt-6 relative">
        <div class="absolute top-0 left-0 w-1/3 h-full bg-primary-gold"></div>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="process-slide w-[80vw] md:w-[45vw] lg:w-[35vw] flex-shrink-0 h-full p-8 md:p-12 rounded-[2rem] border border-primary-gold/55 bg-[#121212] flex flex-col justify-between relative overflow-hidden group hover:border-primary-gold/50 transition-colors duration-300">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-gold/[0.02] to-transparent opacity-100"></div>
      <div class="text-6xl md:text-8xl font-serif-italic text-primary-gold/10 font-normal select-none group-hover:text-primary-gold/25 transition-colors duration-500">02</div>
      <div>
        <h3 class="text-xl md:text-2xl font-bold mb-4">Aurelius Framing</h3>
        <p class="font-mono-tag text-[10px] text-white/50 leading-relaxed uppercase tracking-wider">
          Diseñamos una interfaz premium centrada en la psicología de conversión de lujo, jerarquía editorial y minimalismo fino.
        </p>
      </div>
      <div class="w-full h-[1px] bg-primary-gold/30 mt-6 relative">
        <div class="absolute top-0 left-0 w-2/3 h-full bg-primary-gold"></div>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="process-slide w-[80vw] md:w-[45vw] lg:w-[35vw] flex-shrink-0 h-full p-8 md:p-12 rounded-[2rem] border border-primary-gold/55 bg-[#121212] flex flex-col justify-between relative overflow-hidden group hover:border-primary-gold/50 transition-colors duration-300">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-gold/[0.02] to-transparent opacity-100"></div>
      <div class="text-6xl md:text-8xl font-serif-italic text-primary-gold/10 font-normal select-none group-hover:text-primary-gold/25 transition-colors duration-500">03</div>
      <div>
        <h3 class="text-xl md:text-2xl font-bold mb-4">Technical Build</h3>
        <p class="font-mono-tag text-[10px] text-white/50 leading-relaxed uppercase tracking-wider">
          Arquitectura de código limpio con Astro, CSS nativo de alta velocidad, SEO técnico y performance optimizado al milisegundo.
        </p>
      </div>
      <div class="w-full h-[1px] bg-primary-gold/30 mt-6 relative">
        <div class="absolute top-0 left-0 w-full h-full bg-primary-gold"></div>
      </div>
    </div>

    <!-- Step 4 -->
    <div class="process-slide w-[80vw] md:w-[45vw] lg:w-[35vw] flex-shrink-0 h-full p-8 md:p-12 rounded-[2rem] border border-primary-gold/55 bg-[#121212] flex flex-col justify-between relative overflow-hidden group hover:border-primary-gold/50 transition-colors duration-300 mr-24">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-gold/[0.02] to-transparent opacity-100"></div>
      <div class="text-6xl md:text-8xl font-serif-italic text-primary-gold/10 font-normal select-none group-hover:text-primary-gold/25 transition-colors duration-500">04</div>
      <div>
        <h3 class="text-xl md:text-2xl font-bold mb-4">Precision Launch</h3>
        <p class="font-mono-tag text-[10px] text-white/50 leading-relaxed uppercase tracking-wider">
          Despliegue escalable ultrarápido en la nube, con monitoreo continuo de performance para asegurar un impacto comercial duradero.
        </p>
      </div>
      <div class="w-full h-[2px] bg-primary-gold mt-6"></div>
    </div>

  </div>

  <!-- Bottom quote pill row -->
  <div class="w-full flex justify-center relative z-10 mt-4">
    <div class="px-6 py-4 rounded-full border border-primary-gold/70 flex items-center gap-3 bg-[#0e0e0e]/80 backdrop-blur-sm max-w-xl mx-6 text-center justify-center">
      <svg class="w-4 h-4 text-primary-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
      </svg>
      <p class="font-mono-tag text-[9px] text-white tracking-widest uppercase italic">
        "Mi proceso garantiza que cada píxel sume al valor de tu empresa."
      </p>
    </div>
  </div>

</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const setupDragToScroll = (track: HTMLElement, st?: any) => {
    if (!st) return;

    let isDragging = false;
    let startX = 0;
    let dragStartX = 0;
    const dragSpeed = 1.5; // Smooth drag responsiveness multiplier

    const getScrollBounds = () => {
      const start = st.start !== undefined ? st.start : (document.getElementById('process')?.offsetTop || 0);
      const end = st.end !== undefined ? st.end : (start + (track.scrollWidth - window.innerWidth));
      return { start, end };
    };

    // Mouse events
    track.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      dragStartX = gsap.getProperty(track, 'x') as number || 0;
      track.style.cursor = 'grabbing';
      
      // Temporarily disable ScrollTrigger so manual translation doesn't conflict
      st.disable(false);
      e.preventDefault();
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      const deltaX = e.clientX - startX;
      let targetX = dragStartX + deltaX * dragSpeed;
      
      const totalScrollWidth = track.scrollWidth - window.innerWidth;
      const minX = -totalScrollWidth - 24;
      const maxX = 0;
      const clampedX = Math.max(minX, Math.min(maxX, targetX));
      
      // Translate horizontal track directly using GSAP
      gsap.set(track, { x: clampedX });
    });

    window.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      track.style.cursor = 'grab';

      const totalScrollWidth = track.scrollWidth - window.innerWidth;
      const clampedX = gsap.getProperty(track, 'x') as number || 0;
      
      // Map horizontal x translation to scroll progress (0 to 1)
      const progress = Math.max(0, Math.min(1, -clampedX / (totalScrollWidth + 24)));
      
      // Calculate corresponding vertical scroll position
      const bounds = getScrollBounds();
      const targetScroll = bounds.start + progress * (bounds.end - bounds.start);

      // Silently scroll page to match the new progress position
      if (window.lenis) {
        window.lenis.scrollTo(targetScroll, { immediate: true });
      } else {
        window.scrollTo(0, targetScroll);
      }

      // Re-enable and update ScrollTrigger
      st.enable();
      st.refresh();
    });

    // Touch events for intuitive mobile swipe
    track.addEventListener('touchstart', (e) => {
      if (e.touches.length === 1) {
        isDragging = true;
        startX = e.touches[0].clientX;
        dragStartX = gsap.getProperty(track, 'x') as number || 0;
        st.disable(false);
      }
    }, { passive: true });

    track.addEventListener('touchmove', (e) => {
      if (!isDragging || e.touches.length !== 1) return;
      
      const deltaX = e.touches[0].clientX - startX;
      let targetX = dragStartX + deltaX * dragSpeed;
      
      const totalScrollWidth = track.scrollWidth - window.innerWidth;
      const minX = -totalScrollWidth - 24;
      const maxX = 0;
      const clampedX = Math.max(minX, Math.min(maxX, targetX));

      gsap.set(track, { x: clampedX });
      
      if (e.cancelable) e.preventDefault();
    }, { passive: false });

    track.addEventListener('touchend', () => {
      if (!isDragging) return;
      isDragging = false;

      const totalScrollWidth = track.scrollWidth - window.innerWidth;
      const clampedX = gsap.getProperty(track, 'x') as number || 0;
      const progress = Math.max(0, Math.min(1, -clampedX / (totalScrollWidth + 24)));
      
      const bounds = getScrollBounds();
      const targetScroll = bounds.start + progress * (bounds.end - bounds.start);

      if (window.lenis) {
        window.lenis.scrollTo(targetScroll, { immediate: true });
      } else {
        window.scrollTo(0, targetScroll);
      }

      st.enable();
      st.refresh();
    });

    // Set initial grab cursor
    track.style.cursor = 'grab';
  };

  const initHorizontalScroll = () => {
    const track = document.getElementById('slides-track');
    const section = document.getElementById('process');
    
    if (!track || !section) return;

    // Calculate total distance to slide horizontal track leftwards
    const totalScrollWidth = track.scrollWidth - window.innerWidth;

    const anim = gsap.fromTo(track,
      { x: 0 },
      {
        x: -totalScrollWidth - 24, // offset adjustment for clean margin alignment
        ease: 'none',
        scrollTrigger: {
          trigger: section,
          pin: true,           // Pin the entire #process section!
          start: 'top top',    // Start pinning when the section reaches the top of the viewport
          end: () => `+=${Math.max(window.innerHeight * 1.8, totalScrollWidth)}`, // Absorbs scroll momentum, preventing skipping past About section
          scrub: 0.5,            // Bind vertical scroll progress to translation with minimal delay
          invalidateOnRefresh: true,
        }
      }
    );

    // Bind drag-to-scroll events passing the active ScrollTrigger instance
    setupDragToScroll(track, anim.scrollTrigger);
  };

  window.addEventListener('site-loaded', () => {
    initHorizontalScroll();
  });
</script>
