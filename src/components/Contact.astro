<section id="contact" class="py-24 px-6 md:px-12 bg-[#0e0e0e] border-b border-primary-gold/55 overflow-hidden relative">
  
  <div class="max-w-[1280px] w-full mx-auto">
    
    <!-- Cell grid line layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-12">
      
      <!-- Left Cell: Direct CTA -->
      <div class="lg:col-span-8 lg:border-r border-primary-gold/55 lg:pr-12">
        <span class="font-mono-tag text-[9px] text-primary-gold tracking-[0.4em] uppercase mb-4 block">06 / CONTACTO</span>
        <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-8 leading-tight">
          ¿Creamos algo <br />
          <span class="font-serif-italic text-primary-gold font-normal italic capitalize">memorable?</span>
        </h2>
        
        <p class="font-mono-tag text-xs text-white/50 leading-relaxed uppercase tracking-wider max-w-xl mb-12">
          Hablemos sobre tu idea, tus métricas de conversión y cómo elevar la autoridad de tu marca al nivel más alto posible.
        </p>

        <!-- Dynamic Action Channel Row -->
        <div class="flex flex-col sm:flex-row gap-6">
          <a href="mailto:contact@facundoacosta.com" class="inline-flex items-center justify-center bg-primary-gold hover:bg-black text-black hover:text-white px-10 py-5 border border-primary-gold rounded-lg font-mono-tag text-xs font-black uppercase tracking-[0.25em] transition-all duration-300 hover:scale-102 active:scale-98 shadow-[0_10px_30px_rgba(242,202,80,0.25)] hover:shadow-[0_0_35px_rgba(242,202,80,0.5)] gap-3">
            contact@facundoacosta.com
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </a>

          <a href="#" class="group inline-flex items-center justify-center border-2 border-primary-gold/80 hover:border-primary-gold px-10 py-5 rounded-lg font-mono-tag text-xs font-black uppercase tracking-[0.25em] transition-all duration-300 relative overflow-hidden bg-[#0e0e0e]/50 backdrop-blur-sm shadow-[0_8px_32px_rgba(0,0,0,0.5)] hover:shadow-[0_0_25px_rgba(242,202,80,0.3)]">
            <span class="relative z-10 flex items-center gap-3 text-primary-gold group-hover:text-white transition-colors duration-300">
              Agendar Llamada de 15'
              <svg class="w-4 h-4 text-primary-gold group-hover:text-white transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />
              </svg>
            </span>
            <div class="absolute inset-0 bg-black translate-y-full group-hover:translate-y-0 transition-transform duration-300 origin-bottom"></div>
          </a>
        </div>
      </div>

      <!-- Right Cell: Social Grid -->
      <div class="lg:col-span-4 lg:pl-12 flex flex-col justify-between">
        <div>
          <span class="font-mono-tag text-[9px] text-primary-gold tracking-[0.3em] uppercase mb-6 block">REDES SOCIALES</span>
          
          <div class="grid grid-cols-1 gap-4">
            
            <a href="https://linkedin.com" target="_blank" class="group py-4 px-6 border border-primary-gold/55 hover:border-primary-gold/80 rounded-2xl flex justify-between items-center transition-all bg-[#121212]/50 hover:bg-primary-gold/[0.01]">
              <span class="font-mono-tag text-xs text-white/70 uppercase tracking-widest group-hover:text-primary-gold transition-colors">LinkedIn</span>
              <svg class="w-4 h-4 text-primary-gold/40 group-hover:text-primary-gold transition-colors transform group-hover:translate-x-1 duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>

            <a href="https://github.com" target="_blank" class="group py-4 px-6 border border-primary-gold/55 hover:border-primary-gold/80 rounded-2xl flex justify-between items-center transition-all bg-[#121212]/50 hover:bg-primary-gold/[0.01]">
              <span class="font-mono-tag text-xs text-white/70 uppercase tracking-widest group-hover:text-primary-gold transition-colors">GitHub</span>
              <svg class="w-4 h-4 text-primary-gold/40 group-hover:text-primary-gold transition-colors transform group-hover:translate-x-1 duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>

            <a href="https://twitter.com" target="_blank" class="group py-4 px-6 border border-primary-gold/55 hover:border-primary-gold/80 rounded-2xl flex justify-between items-center transition-all bg-[#121212]/50 hover:bg-primary-gold/[0.01]">
              <span class="font-mono-tag text-xs text-white/70 uppercase tracking-widest group-hover:text-primary-gold transition-colors">Twitter</span>
              <svg class="w-4 h-4 text-primary-gold/40 group-hover:text-primary-gold transition-colors transform group-hover:translate-x-1 duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>

          </div>
        </div>

        <div class="mt-12 lg:mt-0 pt-6 border-t border-primary-gold/55">
          <span class="font-mono-tag text-[8px] text-white/30 uppercase tracking-[0.2em]">BUENOS AIRES, AR — HORA LOCAL: <span id="local-time-display">--:--</span></span>
        </div>
      </div>

    </div>

  </div>

</section>

<script>
  // Display local Buenos Aires time (UTC-3)
  const updateLocalTime = () => {
    const timeDisplay = document.getElementById('local-time-display');
    if (!timeDisplay) return;

    const options: Intl.DateTimeFormatOptions = {
      timeZone: 'America/Argentina/Buenos_Aires',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false
    };

    const formattedTime = new Intl.DateTimeFormat('es-AR', options).format(new Date());
    timeDisplay.textContent = formattedTime;
  };

  updateLocalTime();
  setInterval(updateLocalTime, 60000);
</script>
