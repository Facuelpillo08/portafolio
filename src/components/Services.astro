---
---

<section id="services" class="py-24 px-6 md:px-12 max-w-[1440px] mx-auto border-b border-primary-gold/55">
  
  <!-- Header row divided into cells -->
  <div class="grid grid-cols-12 gap-y-8 pb-16 border-b border-primary-gold/55">
    <div class="col-span-12 md:col-span-8 md:border-r border-primary-gold/55 md:pr-12">
      <span class="font-mono-tag text-[9px] text-primary-gold tracking-[0.4em] uppercase mb-4 block">01 / EXPERTISE</span>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight leading-tight">
        Soluciones técnicas con <br />
        <span class="font-serif-italic text-primary-gold font-normal leading-[0.5] capitalize">sentido estético</span>
      </h2>
    </div>
    <div class="col-span-12 md:col-span-4 md:pl-12 flex items-end">
      <p class="font-mono-tag text-xs text-white/50 leading-relaxed uppercase tracking-wider">
        Combinando ingeniería de software avanzada con un ojo clínico para el diseño minimalista de primer nivel.
      </p>
    </div>
  </div>

  <!-- Services grid separated by fine grid cells -->
  <div class="grid grid-cols-1 md:grid-cols-3 w-full">
    
    <!-- Service 1 -->
    <div class="service-card group p-8 md:p-12 border-b md:border-b-0 md:border-r border-primary-gold/55 relative overflow-hidden transition-colors duration-300 hover:bg-primary-gold/[0.02]">
      <!-- Background glow -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary-gold/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      
      <!-- Top header with index -->
      <div class="w-full flex justify-between items-start mb-12 relative z-10">
        <div class="w-12 h-12 rounded-full border border-primary-gold/45 flex items-center justify-center bg-[#0e0e0e] group-hover:border-primary-gold transition-colors duration-300">
          <svg class="w-5 h-5 text-primary-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25a2.25 2.25 0 01-2.25 2.25h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
          </svg>
        </div>
        <span class="font-mono-tag text-xs text-primary-gold/30 group-hover:text-primary-gold/100 transition-colors duration-300">01</span>
      </div>
      
      <!-- Body -->
      <h3 class="text-xl font-bold mb-4 relative z-10">UI/UX Design</h3>
      <p class="font-mono-tag text-[11px] text-white/50 leading-relaxed uppercase tracking-wider relative z-10">
        Interfaces pensadas para la conversión de alta gama, utilizando principios estéticos de diseño editorial y minimalismo puro.
      </p>
      
      <!-- Slide-in bottom line indicator -->
      <div class="absolute bottom-0 left-0 w-full h-[2px] bg-primary-gold scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
    </div>
 
    <!-- Service 2 -->
    <div class="service-card group p-8 md:p-12 border-b md:border-b-0 md:border-r border-primary-gold/55 relative overflow-hidden transition-colors duration-300 hover:bg-primary-gold/[0.02]">
      <!-- Background glow -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary-gold/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      
      <!-- Top header with index -->
      <div class="w-full flex justify-between items-start mb-12 relative z-10">
        <div class="w-12 h-12 rounded-full border border-primary-gold/45 flex items-center justify-center bg-[#0e0e0e] group-hover:border-primary-gold transition-colors duration-300">
          <svg class="w-5 h-5 text-primary-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
        <span class="font-mono-tag text-xs text-primary-gold/30 group-hover:text-primary-gold/100 transition-colors duration-300">02</span>
      </div>
      
      <!-- Body -->
      <h3 class="text-xl font-bold mb-4 relative z-10">Web Performance</h3>
      <p class="font-mono-tag text-[11px] text-white/50 leading-relaxed uppercase tracking-wider relative z-10">
        Desarrollo con Astro y arquitecturas SSG estáticas para lograr tiempos de carga instantáneos, SEO impecable y 100/100 en Lighthouse.
      </p>
      
      <!-- Slide-in bottom line indicator -->
      <div class="absolute bottom-0 left-0 w-full h-[2px] bg-primary-gold scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
    </div>

    <!-- Service 3 -->
    <div class="service-card group p-8 md:p-12 border-primary-gold/55 relative overflow-hidden transition-colors duration-300 hover:bg-primary-gold/[0.02]">
      <!-- Background glow -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary-gold/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      
      <!-- Top header with index -->
      <div class="w-full flex justify-between items-start mb-12 relative z-10">
        <div class="w-12 h-12 rounded-full border border-primary-gold/45 flex items-center justify-center bg-[#0e0e0e] group-hover:border-primary-gold transition-colors duration-300">
          <svg class="w-5 h-5 text-primary-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-.778.099-1.533.284-2.253m0 0L7.5 12" />
          </svg>
        </div>
        <span class="font-mono-tag text-xs text-primary-gold/30 group-hover:text-primary-gold/100 transition-colors duration-300">03</span>
      </div>
      
      <!-- Body -->
      <h3 class="text-xl font-bold mb-4 relative z-10">Fullstack Logic</h3>
      <p class="font-mono-tag text-[11px] text-white/50 leading-relaxed uppercase tracking-wider relative z-10">
        Integración de bases de datos serverless rápidas, sistemas de autenticación y lógica transaccional robusta para aplicaciones fluidas a 60fps.
      </p>
      
      <!-- Slide-in bottom line indicator -->
      <div class="absolute bottom-0 left-0 w-full h-[2px] bg-primary-gold scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
    </div>

  </div>

</section>
