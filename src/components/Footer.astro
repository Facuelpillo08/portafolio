---
---

<footer
  class="py-8 px-6 md:px-12 bg-[#0b0b0b] border-t border-primary-gold/30"
>
  <div class="max-w-[1280px] w-full mx-auto flex flex-col gap-8">
    <!-- Top Row -->
    <div
      class="grid grid-cols-12 items-center gap-y-6"
    >
      <!-- Cell 1: Signature -->
      <div class="col-span-12 md:col-span-4 flex items-center gap-2">
        <span
          class="w-6 h-6 rounded-full bg-primary-gold flex items-center justify-center text-black text-[10px] font-black italic"
          >F</span
        >
        <span
          class="font-mono-tag text-[9px] text-white/40 tracking-[0.3em] uppercase"
          >FACUNDO ACOSTA STUDIO</span
        >
      </div>

      <!-- Cell 2: Quick navigation links/Copyright -->
      <div
        class="col-span-12 md:col-span-4 flex justify-start md:justify-center items-center"
      >
        <span
          class="font-mono-tag text-[9px] text-white/30 uppercase tracking-[0.2em]"
        >
          © 2026 ACOSTA STUDIO. ALL RIGHTS RESERVED.
        </span>
      </div>

      <!-- Cell 3: Back to top -->
      <div
        class="col-span-12 md:col-span-4 flex justify-start md:justify-end items-center"
      >
        <button
          id="back-to-top"
          class="font-mono-tag text-[9px] text-primary-gold tracking-[0.3em] uppercase hover:underline flex items-center gap-2 focus:outline-none"
        >
          VOLVER ARRIBA ↑
        </button>
      </div>
    </div>

    <!-- Faith & Values -->
    <div class="flex flex-col items-center justify-center gap-5 pt-6 border-t border-white/5">
      <svg width="24" height="34" viewBox="0 0 14 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-primary-gold opacity-80">
        <path d="M7 1V19M2 6H12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <p class="font-sans text-[14px] text-white/60 tracking-wide text-center max-w-lg italic font-light">
        "En paz me acostaré, y asimismo dormiré; Porque solo tú, Jehová, me haces estar confiado."
        <br/>
        <span class="not-italic text-[11px] text-primary-gold/80 uppercase tracking-[0.2em] mt-3 inline-block font-mono-tag">
          — Salmos 4:8
        </span>
      </p>
    </div>
  </div>
</footer>

<script>
  // Smooth scroll back to top using Lenis
  const backToTopBtn = document.getElementById("back-to-top");

  if (backToTopBtn) {
    backToTopBtn.addEventListener("click", () => {
      if (window.lenis) {
        window.lenis.scrollTo(0, { duration: 1.5 });
      } else {
        window.scrollTo({ top: 0, behavior: "smooth" });
      }
    });
  }
</script>
